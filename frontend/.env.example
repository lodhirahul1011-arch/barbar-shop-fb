# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# WHATSAPP_API_TOKEN: Permanent access token for WhatsApp Business API
# WHATSAPP_PHONE_NUMBER_ID: Phone number ID for the business account
WHATSAPP_API_TOKEN="MY_WHATSAPP_API_TOKEN"
WHATSAPP_PHONE_NUMBER_ID="MY_WHATSAPP_PHONE_NUMBER_ID"
WHATSAPP_VERIFY_TOKEN="MY_WHATSAPP_VERIFY_TOKEN"

# IMAGEKIT_PUBLIC_KEY: Public key for ImageKit
# IMAGEKIT_PRIVATE_KEY: Private key for ImageKit (Server-side only)
# IMAGEKIT_URL_ENDPOINT: ImageKit URL endpoint
VITE_IMAGEKIT_PUBLIC_KEY="MY_PUBLIC_KEY"
IMAGEKIT_PRIVATE_KEY="MY_PRIVATE_KEY"
VITE_IMAGEKIT_URL_ENDPOINT="https://ik.imagekit.io/my_id"

# EmailJS frontend notifications
VITE_EMAILJS_SERVICE_ID="service_xxxxxxx"
VITE_EMAILJS_TEMPLATE_ID="template_customer_updates"
VITE_EMAILJS_QUICK_TEMPLATE_ID="template_admin_alerts"
VITE_EMAILJS_PUBLIC_KEY="your_emailjs_public_key"
VITE_ADMIN_EMAIL="owner@example.com"
VITE_CONTACT_EMAIL="owner@example.com"
VITE_ADMIN_NAME="BarberFlow Admin"
VITE_SHOP_NAME="BarberFlow"
